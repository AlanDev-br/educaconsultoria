# ─── SMTP — e-mail de notificação do formulário de contato ────────────────────
# Copie este arquivo para .env.local e preencha com suas credenciais reais.
# NUNCA faça commit do arquivo .env.local.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app

# Endereço que receberá as mensagens do formulário
CONTACT_EMAIL=educaconsultoriaeservicos@gmail.com

# ─── Opcional — URL pública (necessário para Open Graph / sitemaps) ───────────
NEXT_PUBLIC_SITE_URL=https://educaconsultoria.com.br
